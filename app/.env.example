# ─── Dev: Anthropic direkt ───────────────────────────────────────────────────
# Nur für lokalen Dev-Betrieb (npm run dev)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─── Globale Provider-Konfiguration (wird in den Build eingebaut) ────────────
# Legt fest, welcher Provider für ALLE User verwendet wird (ohne Admin-Login).
# Admin-Einstellungen im /#admin-Panel haben immer Vorrang.

# Standard-Provider: claude | openai | gemini | openrouter
VITE_DEFAULT_PROVIDER=openrouter

# Standard-Modell für den gewählten Provider
VITE_DEFAULT_MODEL=google/gemini-2.0-flash-exp:free

# API-Keys je Provider (nur den/die benötigten setzen)
VITE_OPENROUTER_KEY=sk-or-...
VITE_CLAUDE_KEY=sk-ant-...
VITE_OPENAI_KEY=sk-...
VITE_GEMINI_KEY=...
